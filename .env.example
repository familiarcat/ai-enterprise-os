# ═══════════════════════════════════════════════════════════════════════════════
# Sovereign Factory — Environment Variables
# Copy this to .env and fill in the values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── OpenRouter (required for all LLM calls) ───────────────────────────────────
OPENROUTER_API_KEY=

# ── Per-persona model overrides (optional — defaults set in mcp-http-bridge.mjs)
# MODEL_CREW_MANAGER=anthropic/claude-3-haiku
# MODEL_ARCHITECT=anthropic/claude-3-haiku
# MODEL_DEVELOPER=anthropic/claude-3-5-sonnet
# MODEL_INTEGRATION=openai/gpt-4o-mini
# MODEL_QA_AUDITOR=openai/gpt-4o-mini
# MODEL_ANALYST=anthropic/claude-3-haiku
# MODEL_COST_OPT=google/gemini-flash-1.5

# ── Supabase (vector memory for mission recall) ───────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── Redis (distributed scaffolding locks) ────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── MCP HTTP bridge ───────────────────────────────────────────────────────────
MCP_BRIDGE_PORT=3002
# Optional: lock bridge to a specific API key
# MCP_BRIDGE_API_KEY=
# Optional: restrict CORS origin (default: *)
# MCP_BRIDGE_CORS_ORIGIN=http://localhost:3000

# ── Express API server ────────────────────────────────────────────────────────
PORT=3001

# ── alex-dashboard (openrouter-crew-platform) ────────────────────────────────
NEXT_PUBLIC_MCP_URL=http://localhost:3002

# ── OpenRouter metadata headers ──────────────────────────────────────────────
OPENROUTER_REFERER=http://localhost:3000
AI_APP_NAME=sovereign-factory

# ── Python environment ────────────────────────────────────────────────────────
# PYTHON_BIN=/path/to/.venv/bin/python3   (auto-detected if not set)
# CREW_MODEL=anthropic/claude-3-haiku     (default model for crew_manager.py)

# ── AWS (Phase 4 — production deploy) ────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_PROFILE=openrouter-deployer
# ECR_REPO=sovereign-factory
# ECS_CLUSTER=sovereign-factory
# ECS_SERVICE=mcp-bridge

# ── Vercel (Phase 4) ──────────────────────────────────────────────────────────
# NEXT_PUBLIC_MCP_URL_PROD=https://your-ecs-url.amazonaws.com

# ── n8n (Phase 3) ────────────────────────────────────────────────────────────
# N8N_PORT=5678
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=changeme
# N8N_WEBHOOK_SECRET=your-hmac-secret
